{
  "title": "AI Employee Platform Health",
  "panels": [
    {
      "type": "timeseries",
      "title": "Pipeline Throughput (AI Gateway Calls)",
      "targets": [
        {
          "expr": "rate(ai_gateway_calls_total[5m])",
          "legendFormat": "{{model_name}} - {{tenant_id}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rates",
      "targets": [
        {
          "expr": "rate(workflow_errors_total[5m])",
          "legendFormat": "{{agent_name}}"
        }
      ]
    },
    {
      "type": "heatmap",
      "title": "Per-Agent Latency",
      "targets": [
        {
          "expr": "rate(agent_execution_latency_seconds_bucket[5m])",
          "format": "heatmap"
        }
      ]
    }
  ]
}
